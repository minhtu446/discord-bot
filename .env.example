# Discord Bot Configuration
# Copy this to .env and fill in your values
# Các giá trị ở đây sẽ ghi đè lên config.json

DISCORD_TOKEN=your_discord_bot_token_here
HF_TOKEN=your_huggingface_token_here
OWNER_ID=your_discord_user_id
CLIENT_ID=your_bot_client_id
GUILD_ID=your_main_guild_id
WELCOME_CHANNEL_ID=channel_id
LOG_CHANNEL_ID=channel_id
TICKET_CATEGORY_ID=category_id
MEMBER_ROLE_ID=role_id
SETUP_CATEGORY_ID=category_id
DM_RELAY_CHANNEL_ID=channel_id

# OCR.space API key for image text detection (optional, free tier: 25k req/month)
# Get your key at: https://ocr.space/OCRAPI
OCRSPACE_API_KEY=your_ocr_space_api_key_here
